{
    "name": "Node.js, Express, React, MongoDB & Tailwind",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".",
        "args": {
            "USER_UID": "1001",
		    "USER_GID": "1001"
        }
    },
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    // "features": {
    //     "ghcr.io/devcontainers/features/node:1": {
    //         "nodeGypDependencies": true,
    //         "version": "lts",
    //         "nvmVersion": "latest"
    //     }
    // },    
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2.4.4": {
            // "userUid": "1000",
            // "userGid": "1000",
            "username": "daytona"
        },
        "ghcr.io/devcontainers/features/node:1": {
            // "version": "lts",
            // "nvmVersion": "latest"
        }
    },  
    "portsAttributes": {
        "5174": {
            "label": "Frontend",
            "onAutoForward": "openPreview"
        },
        "8000": {
            "label": "Backend",
            "onAutoForward": "openPreview"
        },
        "27017": {
            "label": "MongoDB",
            "onAutoForward": "ignore"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "mongodb.mongodb-vscode",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "bradlc.vscode-tailwindcss",
                "davidanson.vscode-markdownlint"
            ]
        }
    },
    // "postCreateCommand": "cd backend && sudo npm install && cd ../frontend && sudo npm install"
    "postCreateCommand": "cd backend && npm install",
    "remoteUser": "daytona"
}